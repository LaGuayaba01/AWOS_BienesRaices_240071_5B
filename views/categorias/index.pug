extends ../layout/index

block contenido

    //- ── Hero de categoría ──────────────────────────────────────
    - const iconos = { casa: 'M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z', departamento: 'M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z', terreno: '' }
    - const colores = { casa: '#6d28d9', departamento: '#7c3aed', terreno: '#5b21b6' }
    - const subtitulos = { casa: 'Descubre casas ideales para vivir con tu familia.', departamento: 'Espacios modernos en las mejores ubicaciones.', terreno: 'Invierte en el terreno perfecto para tus proyectos.' }

    .relative.overflow-hidden.rounded-xl.mb-5(style=`background: linear-gradient(135deg, #3b0764 0%, ${colores[categoria] || '#7c3aed'} 60%, #6d28d9 100%); min-height: 150px;`)

        .absolute.inset-0(style="opacity:0.07; background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px), radial-gradient(circle at 80% 20%, white 1px, transparent 1px); background-size: 40px 40px;")

        .relative.px-6.py-8.flex.flex-col.items-center.text-center

            //- Breadcrumb
            .flex.items-center.gap-2.mb-3
                a(href="/" style="color:#c4b5fd; font-size:12px; text-decoration:none;") Inicio
                svg(xmlns="http://www.w3.org/2000/svg" style="width:10px;height:10px;color:#a78bfa;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                    path(stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5")
                span(style="color:#e9d5ff; font-size:12px;")= titulo

            //- Icono
            .w-14.h-14.rounded-2xl.flex.items-center.justify-center.mb-3(style="background: rgba(255,255,255,0.15); backdrop-filter:blur(4px);")
                if categoria === 'terreno'
                    svg(xmlns="http://www.w3.org/2000/svg" style="width:28px;height:28px;color:white;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                        path(stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z")
                else
                    svg(xmlns="http://www.w3.org/2000/svg" style="width:28px;height:28px;color:white;" fill="currentColor" viewBox="0 0 20 20")
                        path(d=iconos[categoria] fill-rule="evenodd" clip-rule="evenodd")

            h1.text-white.font-extrabold.mb-1(style="font-size:1.5rem; line-height:1.2;")= titulo

            p.text-purple-200.mb-4(style="font-size:13px; max-width:360px;")= subtitulos[categoria] || ''

            //- Buscador rápido en la categoría
            form(method="GET" action=`/categorias/${categoria}`)
                .flex.items-center.gap-2.bg-white.rounded-xl.shadow-lg(style="max-width:420px; width:100%; padding:6px;")
                    .relative.flex-1
                        input(
                            type="text"
                            name="buscar"
                            value=buscar
                            placeholder="Buscar por título, ciudad o dirección..."
                            style="width:100%; border:none; padding:6px 10px 6px 32px; border-radius:10px; font-size:13px; color:#1f2937; background:transparent; outline:none;"
                        )
                        svg(xmlns="http://www.w3.org/2000/svg" style="width:14px; height:14px; color:#a78bfa; position:absolute; left:10px; top:50%; transform:translateY(-50%); pointer-events:none;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z")
                    input(type="hidden" name="limite" value=limite)
                    button(
                        type="submit"
                        style="background:#7c3aed; color:white; border:none; padding:6px 16px; border-radius:10px; font-size:12px; font-weight:600; cursor:pointer; white-space:nowrap; transition:background 0.2s;"
                        onmouseover="this.style.background='#6d28d9'"
                        onmouseout="this.style.background='#7c3aed'"
                    ) Buscar

            //- Contador
            .mt-3.flex.items-center.gap-2
                span.w-2.h-2.rounded-full.bg-green-400
                p.text-purple-200(style="font-size:12px;")= totalResultados + ' propiedades disponibles'

    //- ── Otras categorías (tabs rápidos) ─────────────────────────
    .flex.items-center.gap-2.mb-4.flex-wrap

        a(
            href="/"
            style="display:inline-flex; align-items:center; gap:6px; background:white; color:#6b7280; padding:6px 14px; border-radius:999px; font-size:12px; font-weight:500; text-decoration:none; border:1px solid #e5e7eb; transition:all 0.2s;"
            onmouseover="this.style.borderColor='#a78bfa'; this.style.color='#7c3aed';"
            onmouseout="this.style.borderColor='#e5e7eb'; this.style.color='#6b7280';"
        ) ← Todas las categorías

        each cat in ['casa', 'departamento', 'terreno']
            - const labels = { casa: '🏠 Casas', departamento: '🏢 Deptos', terreno: '🌿 Terrenos' }
            - const isActive = cat === categoria
            a(
                href=`/categorias/${cat}`
                style=`display:inline-flex; align-items:center; gap:6px; padding:6px 14px; border-radius:999px; font-size:12px; font-weight:${isActive ? '700' : '500'}; text-decoration:none; border:1px solid ${isActive ? '#7c3aed' : '#e5e7eb'}; background:${isActive ? '#7c3aed' : 'white'}; color:${isActive ? 'white' : '#6b7280'}; transition:all 0.2s;`
            )= labels[cat]

    //- ── Filtro ciudad ───────────────────────────────────────────
    if ciudades && ciudades.length > 1
        form.mb-4(method="GET" action=`/categorias/${categoria}`)
            input(type="hidden" name="buscar" value=buscar)
            input(type="hidden" name="limite" value=limite)
            .bg-white.rounded-xl.border.border-purple-100.shadow-sm.px-4.py-2.flex.items-center.gap-3.flex-wrap
                span.text-xs.text-gray-400.font-semibold.uppercase.tracking-wide Ciudad
                each c in ciudades
                    - const isActive = c === ciudadActiva
                    button(
                        type="submit"
                        name="ciudad"
                        value=c
                        style=`padding:4px 12px; border-radius:999px; border:1px solid ${isActive ? '#7c3aed' : '#e9d5ff'}; background:${isActive ? '#7c3aed' : 'transparent'}; color:${isActive ? 'white' : '#7c3aed'}; font-size:12px; font-weight:${isActive ? '600' : '400'}; cursor:pointer; transition:all 0.2s;`
                    )= c
                if ciudadActiva
                    a(href=`/categorias/${categoria}` style="font-size:11px; color:#9ca3af; text-decoration:none; margin-left:4px;") ✕ Limpiar

    //- ── Grid de propiedades ─────────────────────────────────────
    if propiedades && propiedades.length > 0

        .grid.gap-4(style="grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));")

            each p in propiedades

                article.bg-white.rounded-2xl.shadow-sm.overflow-hidden(style="border:1px solid #f3e8ff; transition:box-shadow 0.2s; display:flex; flex-direction:column;" onmouseover="this.style.boxShadow='0 4px 20px rgba(124,58,237,0.13)'" onmouseout="this.style.boxShadow=''")

                    //- Imagen
                    .relative(style="height:160px; background: linear-gradient(135deg,#ede9fe,#f3f4f6); overflow:hidden;")
                        if p.imagenes && p.imagenes.length > 0
                            img(src=p.imagenes[0] alt=p.titulo style="width:100%; height:100%; object-fit:cover;")
                        else
                            .flex.items-center.justify-center.h-full
                                svg(xmlns="http://www.w3.org/2000/svg" style="width:40px;height:40px;color:#d8b4fe;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z")

                        //- Badge categoría
                        span.absolute(style="top:8px; left:8px; background:#7c3aed; color:white; font-size:10px; font-weight:700; padding:3px 8px; border-radius:999px; text-transform:capitalize;")= p.categoria

                    //- Info
                    .px-4.py-3.flex.flex-col.flex-1

                        p.font-bold.text-gray-800.mb-1.leading-tight(style="font-size:14px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;")= p.titulo

                        .flex.items-center.gap-1.mb-2
                            svg(xmlns="http://www.w3.org/2000/svg" style="width:11px;height:11px;color:#a78bfa;flex-shrink:0;" fill="currentColor" viewBox="0 0 20 20")
                                path(fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd")
                            p(style="font-size:11px; color:#6b7280; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;")= p.ciudad

                        .flex.items-center.gap-3.mb-3
                            .flex.items-center.gap-1
                                svg(xmlns="http://www.w3.org/2000/svg" style="width:12px;height:12px;color:#a78bfa;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25")
                                span(style="font-size:11px; color:#6b7280;")= p.habitaciones + ' hab.'
                            .flex.items-center.gap-1
                                svg(xmlns="http://www.w3.org/2000/svg" style="width:12px;height:12px;color:#a78bfa;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6")
                                span(style="font-size:11px; color:#6b7280;")= p.banos + ' baños'
                            if p.estacionamientos > 0
                                .flex.items-center.gap-1
                                    svg(xmlns="http://www.w3.org/2000/svg" style="width:12px;height:12px;color:#a78bfa;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                        path(stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25")
                                    span(style="font-size:11px; color:#6b7280;")= p.estacionamientos + ' est.'

                        .flex.items-center.justify-between.mt-auto
                            p.font-extrabold.text-purple-700(style="font-size:15px;")= '$' + Number(p.precio).toLocaleString('es-MX')
                            a(href=`/propiedad/${p.id}` style="background:#7c3aed; color:white; font-size:11px; font-weight:600; padding:5px 12px; border-radius:8px; text-decoration:none; transition:background 0.2s;" onmouseover="this.style.background='#6d28d9'" onmouseout="this.style.background='#7c3aed'") Ver detalle

        //- ── Paginador ───────────────────────────────────────────
        if totalPaginas > 1
            .mt-6.flex.items-center.justify-center.gap-1.flex-wrap

                if paginaActual > 1
                    a(href=`/categorias/${categoria}?pagina=${paginaActual-1}&limite=${limite}&buscar=${encodeURIComponent(buscar)}&ciudad=${encodeURIComponent(ciudadActiva)}` class="flex items-center gap-1 text-xs border border-purple-200 text-purple-600 hover:bg-purple-50 px-3 py-1 rounded-lg transition-all duration-200")
                        svg(xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5")
                        | Anterior

                - var ini = Math.max(1, paginaActual - 2)
                - var fin = Math.min(totalPaginas, paginaActual + 2)

                - for (var i = ini; i <= fin; i++)
                    if i === paginaActual
                        span.text-xs.bg-purple-600.text-white.font-bold.px-3(style="padding-top:6px;padding-bottom:6px;border-radius:0.5rem")= i
                    else
                        a(href=`/categorias/${categoria}?pagina=${i}&limite=${limite}&buscar=${encodeURIComponent(buscar)}&ciudad=${encodeURIComponent(ciudadActiva)}` class="text-xs border border-purple-200 text-purple-600 hover:bg-purple-50 px-3 py-1 rounded-lg")= i

                if paginaActual < totalPaginas
                    a(href=`/categorias/${categoria}?pagina=${paginaActual+1}&limite=${limite}&buscar=${encodeURIComponent(buscar)}&ciudad=${encodeURIComponent(ciudadActiva)}` class="flex items-center gap-1 text-xs border border-purple-200 text-purple-600 hover:bg-purple-50 px-3 py-1 rounded-lg transition-all duration-200")
                        | Siguiente
                        svg(xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5")

    else
        //- Estado vacío
        .flex.flex-col.items-center.justify-center.py-16.text-center
            .w-16.h-16.rounded-full.flex.items-center.justify-center.mb-3(style="background:linear-gradient(135deg,#ede9fe,#f3f4f6)")
                svg(xmlns="http://www.w3.org/2000/svg" style="width:32px;height:32px;color:#c4b5fd;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1")
                    path(stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H15a.75.75 0 01-.75-.75v-4.5h-4.5V21a.75.75 0 01-.75.75H3.75A.75.75 0 013 21V9.75z")
            if buscar || ciudadActiva
                h2.text-gray-600.font-bold.mb-1(style="font-size:15px;") Sin resultados
                p.text-gray-400.mb-3(style="font-size:13px;") No encontramos propiedades con esos filtros.
                a(href=`/categorias/${categoria}` style="color:#7c3aed; font-size:13px; font-weight:600;") Limpiar búsqueda
            else
                h2.text-gray-600.font-bold.mb-1(style="font-size:15px;")= 'Sin ' + titulo + ' disponibles'
                p.text-gray-400.mb-3(style="font-size:13px;") Vuelve pronto, se publicarán nuevas propiedades.
                a(href="/" style="color:#7c3aed; font-size:13px; font-weight:600;") Ver todas las propiedades

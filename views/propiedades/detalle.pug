extends ../layout/index

block contenido
    .py-6.mx-auto.max-w-4xl

        //- Encabezado con navegación
        .mb-6.flex.items-center.justify-between.flex-wrap.gap-3
            .flex.items-center.gap-3
                a(href="/propiedades" class="text-purple-400 hover:text-purple-600 transition-colors duration-200")
                    svg(xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                        path(stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18")
                .flex.flex-col
                    h1.text-2xl.font-extrabold.text-purple-700= propiedad.titulo
                    .flex.items-center.gap-2.mt-1
                        span(class=`text-xs font-medium px-2 rounded-full ${propiedad.estatus === 'activa' ? 'bg-green-100 text-green-700' : propiedad.estatus === 'vendida' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-500'}` style="padding-top:2px;padding-bottom:2px")
                            = propiedad.estatus === 'activa' ? 'Disponible' : propiedad.estatus === 'vendida' ? 'Vendida' : 'Inactiva'
                        span.text-xs.text-gray-400.capitalize= propiedad.categoria

            //- Botones de acción del dueño
            if esDueno
                a(href=`/propiedades/editar/${propiedad.id}` class="flex items-center gap-2 border border-purple-300 text-purple-600 hover:bg-purple-50 text-sm font-medium px-4 py-2 rounded-xl transition-all duration-200")
                    svg(xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                        path(stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125")
                    | Editar

        .grid.gap-6(class="lg:grid-cols-3")

            //- Columna izquierda — Galería + info principal
            div(class="lg:col-span-2 flex flex-col gap-6")

                //- Galería de imágenes
                .bg-white.rounded-2xl.shadow-md.overflow-hidden.border.border-purple-100
                    if propiedad.imagenes && propiedad.imagenes.length > 0
                        //- Imagen principal
                        .relative
                            img#imgPrincipal(
                                src=propiedad.imagenes[0]
                                alt=propiedad.titulo
                                class="w-full object-cover"
                                style="height:320px"
                            )
                            if propiedad.imagenes.length > 1
                                span(class="absolute bottom-3 right-3 bg-black/50 text-white text-xs px-2 py-1 rounded-lg")
                                    | 1 /#{propiedad.imagenes.length}
                                #contadorImg(style="display:none") 1

                        //- Miniaturas
                        if propiedad.imagenes.length > 1
                            .flex.gap-2.p-3.overflow-x-auto
                                each img, i in propiedad.imagenes
                                    img(
                                        src=img
                                        alt=`Imagen ${i + 1}`
                                        class="w-16 h-16 object-cover rounded-xl cursor-pointer border-2 border-transparent hover:border-purple-400 transition-all duration-200 flex-shrink-0"
                                        onclick=`cambiarImagen('${img}', ${i + 1})`
                                    )
                    else
                        .bg-purple-50.flex.items-center.justify-center(style="height:280px")
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-purple-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H15a.75.75 0 01-.75-.75v-4.5h-4.5V21a.75.75 0 01-.75.75H3.75A.75.75 0 013 21V9.75z")
                            p.text-gray-400.text-sm.mt-2 Sin imágenes

                //- Descripción
                .bg-white.rounded-2xl.shadow-md.border.border-purple-100.p-6
                    h2.text-sm.font-bold.text-gray-700.uppercase.tracking-wide.mb-3 Descripción
                    p.text-sm.text-gray-600.leading-relaxed= propiedad.descripcion

            //- Columna derecha — Detalles
            .flex.flex-col.gap-4

                //- Precio
                .bg-white.rounded-2xl.shadow-md.border.border-purple-100.p-6
                    p.text-xs.text-gray-400.uppercase.font-bold.mb-1 Precio
                    p.text-3xl.font-extrabold.text-purple-600= '$' + Number(propiedad.precio).toLocaleString('es-MX')

                //- Características
                .bg-white.rounded-2xl.shadow-md.border.border-purple-100.p-6
                    h2.text-sm.font-bold.text-gray-700.uppercase.tracking-wide.mb-4 Características

                    .grid.grid-cols-3.gap-3

                        .flex.flex-col.items-center.bg-purple-50.rounded-xl.p-3
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-500 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25")
                            span.text-lg.font-bold.text-gray-800= propiedad.habitaciones
                            span.text-xs.text-gray-500 Hab.

                        .flex.flex-col.items-center.bg-purple-50.rounded-xl.p-3
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-500 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6")
                            span.text-lg.font-bold.text-gray-800= propiedad.banos
                            span.text-xs.text-gray-500 Baños

                        .flex.flex-col.items-center.bg-purple-50.rounded-xl.p-3
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-500 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12")
                            span.text-lg.font-bold.text-gray-800= propiedad.estacionamientos
                            span.text-xs.text-gray-500 Est.

                //- Ubicación
                .bg-white.rounded-2xl.shadow-md.border.border-purple-100.p-6
                    h2.text-sm.font-bold.text-gray-700.uppercase.tracking-wide.mb-3 Ubicación
                    .flex.items-start.gap-2.mb-2
                        svg(xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-purple-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z")
                        .flex.flex-col
                            span.text-sm.font-medium.text-gray-700= propiedad.ciudad
                            span.text-xs.text-gray-500= propiedad.direccion

                //- Fecha de publicación
                .bg-white.rounded-2xl.shadow-md.border.border-purple-100.p-6
                    h2.text-sm.font-bold.text-gray-700.uppercase.tracking-wide.mb-3 Publicado
                    p.text-sm.text-gray-600= new Date(propiedad.created_at).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })

block scripts
    script.
        // ── Galería de imágenes ────────────────────────────────────
        function cambiarImagen(src, num) {
            const img = document.getElementById('imgPrincipal');
            const contador = document.querySelector('[class*="bottom-3"]');
            if (img) img.src = src;
            if (contador) {
                const total = document.querySelectorAll('[onclick^="cambiarImagen"]').length + 1;
                contador.textContent = `${num} /${total}`;
            }
            // Resaltar miniatura activa
            document.querySelectorAll('[onclick^="cambiarImagen"]').forEach(t => {
                t.classList.toggle('border-purple-500', t.getAttribute('onclick').includes(`'${src}'`));
                t.classList.toggle('border-transparent', !t.getAttribute('onclick').includes(`'${src}'`));
            });
        }

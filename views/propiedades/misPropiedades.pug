extends ../layout/index

block contenido
    .py-6

        .mb-6.flex.items-start.justify-between.flex-wrap.gap-3
            div
                h1.text-2xl.font-extrabold.text-blue-600 Mis Propiedades
                p.text-sm.text-gray-500.mt-1 Bienvenid@, &nbsp;
                    strong.text-blue-600= usuarioActual.name
                    | . Aqui encontraras todas tus propiedades registradas.

            a(href="/propiedades/nueva" class="flex items-center gap-2 bg-sky-500 hover:bg-sky-600 text-white text-xs font-medium px-4 py-2 rounded-xl transition-all duration-200")
                svg(xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                    path(stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15")
                | Nueva Propiedad

        if errores
            each error in errores
                span(data-alerta-error=error.msg style="display:none")

        if success
            span(data-alerta-exito=success style="display:none")

        //- ── Buscador y filtros ──────────────────────────────────
        form.mb-4(method="GET" action="/propiedades")
            .bg-white.rounded-2xl.border.border-blue-100.shadow-sm.p-4

                //- Fila 1: buscador + botones
                .flex.items-center.gap-3.mb-3.flex-wrap

                    //- Buscador
                    .flex-1(style="min-width:200px; position:relative;")
                        input(
                            type="text"
                            name="buscar"
                            value=buscar
                            placeholder="Buscar por título o ciudad..."
                            style="width:100%; border:1px solid #bae6fd; padding:8px 12px 8px 36px; border-radius:12px; font-size:14px; color:#1f2937; background:#fff; outline:none; transition:all 0.2s;"
                        )
                        svg(xmlns="http://www.w3.org/2000/svg" style="width:16px; height:16px; color:#38bdf8; position:absolute; left:12px; top:50%; transform:translateY(-50%); pointer-events:none;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z")

                    //- Botones
                    .flex.items-center.gap-2.flex-shrink-0
                        if buscar || categoriaActiva || estatusActivo
                            a(href="/propiedades" class="flex items-center gap-1 text-xs border border-gray-200 text-gray-500 hover:bg-gray-50 px-3 py-2 rounded-xl transition-all duration-200")
                                svg(xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12")
                                | Limpiar
                        button(
                            type="submit"
                            class="flex items-center gap-1 text-xs bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-xl transition-all duration-200 font-medium"
                        )
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z")
                            | Buscar

                //- Fila 2: filtros + items por página — separador visual
                .pt-3.border-t.border-blue-50.flex.items-center.gap-3.flex-wrap

                    //- Filtro categoría
                    .flex.items-center.gap-2
                        span.text-xs.text-gray-400.font-medium.flex-shrink-0 Categoría
                        select(
                            name="categoria"
                            class="border border-blue-100 bg-blue-50 text-blue-700 px-3 py-1.5 rounded-lg text-xs font-medium focus:border-blue-400 focus:outline-none transition-all duration-200"
                        )
                            option(value="" selected=(!categoriaActiva)) Todas
                            option(value="casa"         selected=(categoriaActiva==='casa'))         Casa
                            option(value="departamento" selected=(categoriaActiva==='departamento')) Departamento
                            option(value="terreno"      selected=(categoriaActiva==='terreno'))      Terreno

                    //- Divisor
                    span.text-gray-200.text-sm |

                    //- Filtro estatus
                    .flex.items-center.gap-2
                        span.text-xs.text-gray-400.font-medium.flex-shrink-0 Estatus
                        select(
                            name="estatus"
                            class="border border-blue-100 bg-blue-50 text-blue-700 px-3 py-1.5 rounded-lg text-xs font-medium focus:border-blue-400 focus:outline-none transition-all duration-200"
                        )
                            option(value="" selected=(!estatusActivo)) Todos
                            option(value="activa"   selected=(estatusActivo==='activa'))   Disponible
                            option(value="inactiva" selected=(estatusActivo==='inactiva')) Inactiva

                    //- Divisor
                    span.text-gray-200.text-sm |

                    //- Items por página
                    .flex.items-center.gap-2
                        span.text-xs.text-gray-400.font-medium Mostrar
                        select(
                            name="limite"
                            onchange="this.form.submit()"
                            class="border border-blue-100 bg-blue-50 text-blue-700 px-3 py-1.5 rounded-lg text-xs font-medium focus:border-blue-400 focus:outline-none transition-all duration-200"
                        )
                            option(value="6"  selected=(limite===6))  6
                            option(value="12" selected=(limite===12)) 12
                            option(value="24" selected=(limite===24)) 24
                        span.text-xs.text-gray-400.font-medium por página

        //- ── Contador de resultados ──────────────────────────────
        .mb-3.flex.items-center.justify-between.flex-wrap.gap-2
            p.text-xs.text-gray-400
                if totalResultados === 0
                    | Sin resultados
                else
                    | Mostrando&nbsp;
                    strong.text-gray-600= (paginaActual - 1) * limite + 1
                    | &ndash;
                    strong.text-gray-600= Math.min(paginaActual * limite, totalResultados)
                    | &nbsp;de&nbsp;
                    strong.text-gray-600= totalResultados
                    | &nbsp;propiedades
            if totalPaginas > 1
                p.text-xs.text-gray-400 Página #{paginaActual} de #{totalPaginas}

        if propiedades && propiedades.length > 0
            .grid.gap-4(class="sm:grid-cols-2 lg:grid-cols-3")
                each propiedad in propiedades
                    .bg-white.rounded-2xl.shadow-md.overflow-hidden.border.border-blue-100

                        if propiedad.imagenes && propiedad.imagenes.length > 0
                            img(src=propiedad.imagenes[0] alt=propiedad.titulo class="w-full h-36 object-cover")
                        else
                            .bg-blue-100.h-36.flex.items-center.justify-center
                                svg(xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H15a.75.75 0 01-.75-.75v-4.5h-4.5V21a.75.75 0 01-.75.75H3.75A.75.75 0 013 21V9.75z")

                        .p-4
                            .flex.items-center.justify-between.mb-1
                                span(class=`text-xs font-medium px-2 rounded-full ${propiedad.estatus === 'activa' ? 'bg-green-100 text-green-700' : propiedad.estatus === 'vendida' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-500'}` style="padding-top:2px;padding-bottom:2px")= propiedad.estatus === 'activa' ? 'Disponible' : propiedad.estatus === 'vendida' ? 'Vendida' : 'Inactiva'
                                span.text-xs.text-gray-400.capitalize= propiedad.categoria

                            h3.text-sm.font-bold.text-gray-800.truncate= propiedad.titulo
                            p.text-xs.text-gray-500(style="margin-top:2px")= propiedad.ciudad

                            .flex.items-center.justify-between.mt-2
                                span.text-blue-600.text-sm.font-bold= '$' + Number(propiedad.precio).toLocaleString('es-MX')
                                .flex.items-center.gap-2.text-xs.text-gray-400
                                    span= propiedad.habitaciones + ' hab'
                                    span= propiedad.banos + ' baños'

                            .flex.items-center.gap-2.mt-3
                                a(href=`/propiedades/${propiedad.id}` class="flex-1 text-center text-xs border border-blue-200 text-gray-500 hover:bg-gray-50 py-1.5 rounded-lg transition-all duration-200") Ver
                                a(href=`/propiedades/editar/${propiedad.id}` class="flex-1 text-center text-xs border border-blue-300 text-blue-600 hover:bg-blue-50 py-1.5 rounded-lg transition-all duration-200") Editar
                                form(method="POST" action=`/propiedades/estatus/${propiedad.id}` style="flex:1")
                                    input(type="hidden" name="_csrf" value=csrfToken)
                                    button(
                                        type="submit"
                                        title=`Estatus actual: ${propiedad.estatus === 'activa' ? 'Disponible' : propiedad.estatus === 'vendida' ? 'Vendida' : 'Inactiva'} — click para cambiar`
                                        class=`w-full text-xs py-1.5 rounded-lg border transition-all duration-200 font-medium ${propiedad.estatus === 'activa' ? 'border-green-300 text-green-600 hover:bg-green-50' : propiedad.estatus === 'vendida' ? 'border-blue-300 text-blue-600 hover:bg-blue-50' : 'border-gray-300 text-gray-500 hover:bg-gray-50'}`
                                    )= propiedad.estatus === 'activa' ? '🟢' : propiedad.estatus === 'vendida' ? '🔵' : '⚫'
                                button(
                                    type="button"
                                    onclick=`abrirModalEliminar('${propiedad.id}', '${propiedad.titulo.replace(/'/g, "\\'")}')`
                                    class="text-xs border border-red-200 text-red-500 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all duration-200"
                                ) Eliminar

            //- ── Paginador ───────────────────────────────────────
            if totalPaginas > 1
                .mt-6.flex.items-center.justify-center.gap-1.flex-wrap

                    if paginaActual > 1
                        a(href=`/propiedades?pagina=${paginaActual - 1}&limite=${limite}&buscar=${encodeURIComponent(buscar)}&categoria=${categoriaActiva}&estatus=${estatusActivo}` class="flex items-center gap-1 text-xs border border-blue-200 text-black-600 hover:bg-blue-50 px-3 py-1.5 rounded-lg transition-all duration-200")
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5")
                            | Anterior
                    else
                        span.flex.items-center.gap-1.text-xs.border.border-gray-100.text-gray-300.px-3(style="padding-top:6px;padding-bottom:6px;border-radius:0.5rem")
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5")
                            | Anterior

                    - var inicio = Math.max(1, paginaActual - 2)
                    - var fin    = Math.min(totalPaginas, paginaActual + 2)
                    if inicio > 1
                        a(href=`/propiedades?pagina=1&limite=${limite}&buscar=${encodeURIComponent(buscar)}&categoria=${categoriaActiva}&estatus=${estatusActivo}` class="text-xs border border-blue-200 text-blue-600 hover:bg-blue-50 px-3 py-1.5 rounded-lg") 1
                        if inicio > 2
                            span.text-xs.text-gray-400.px-1 …

                    - for (var i = inicio; i <= fin; i++)
                        if i === paginaActual
                            span.text-xs.bg-blue-600.text-white.font-bold.px-3(style="padding-top:6px;padding-bottom:6px;border-radius:0.5rem")= i
                        else
                            a(href=`/propiedades?pagina=${i}&limite=${limite}&buscar=${encodeURIComponent(buscar)}&categoria=${categoriaActiva}&estatus=${estatusActivo}` class="text-xs border border-blue-200 text-blue-600 hover:bg-blue-50 px-3 py-1.5 rounded-lg")= i

                    if fin < totalPaginas
                        if fin < totalPaginas - 1
                            span.text-xs.text-gray-400.px-1 …
                        a(href=`/propiedades?pagina=${totalPaginas}&limite=${limite}&buscar=${encodeURIComponent(buscar)}&categoria=${categoriaActiva}&estatus=${estatusActivo}` class="text-xs border border-blue-200 text-blue-600 hover:bg-blue-50 px-3 py-1.5 rounded-lg")= totalPaginas

                    if paginaActual < totalPaginas
                        a(href=`/propiedades?pagina=${paginaActual + 1}&limite=${limite}&buscar=${encodeURIComponent(buscar)}&categoria=${categoriaActiva}&estatus=${estatusActivo}` class="flex items-center gap-1 text-xs border border-blue-200 text-blue-600 hover:bg-blue-50 px-3 py-1.5 rounded-lg transition-all duration-200")
                            | Siguiente
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5")
                    else
                        span.flex.items-center.gap-1.text-xs.border.border-gray-100.text-gray-300.px-3(style="padding-top:6px;padding-bottom:6px;border-radius:0.5rem")
                            | Siguiente
                            svg(xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                                path(stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5")

        else
            .flex.flex-col.items-center.justify-center.py-20.text-center
                svg(xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-blue-200 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1")
                    path(stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H15a.75.75 0 01-.75-.75v-4.5h-4.5V21a.75.75 0 01-.75.75H3.75A.75.75 0 013 21V9.75z")
                if buscar || categoriaActiva || estatusActivo
                    p.text-gray-400.text-sm.mb-4 No se encontraron propiedades con esos filtros.
                    a(href="/propiedades" class="text-blue-600 text-sm font-medium hover:underline") Limpiar filtros
                else
                    p.text-gray-400.text-sm.mb-4 Aun no tienes propiedades registradas.
                    a(href="/propiedades/nueva" class="bg-sky-500 hover:bg-sky-600 text-white text-sm font-medium px-6 py-2 rounded-xl transition-all duration-200") Agregar mi primera propiedad

    //- ── Modal eliminación ───────────────────────────────────────
    #modalEliminar(class="fixed inset-0 z-50 flex items-center justify-center hidden" aria-modal="true")
        .absolute.inset-0.bg-black.bg-opacity-50(onclick="cerrarModalEliminar()")
        .relative.bg-white.rounded-2xl.shadow-2xl.p-6.mx-4(class="w-full max-w-sm")
            .flex.justify-center.mb-4
                .w-14.h-14.rounded-full.bg-red-100.flex.items-center.justify-center
                    svg(xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                        path(stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")
            h3.text-center.text-base.font-bold.text-gray-800.mb-1 ¿Eliminar propiedad?
            p#modalTitulo.text-center.text-sm.text-gray-500.mb-5
            p.text-center.text-xs.text-red-400.mb-5 Esta accion no se puede deshacer.
            form#formEliminar(method="POST" action="")
                input(type="hidden" name="_csrf" value=csrfToken)
                .flex.gap-3
                    button(type="button" onclick="cerrarModalEliminar()" class="flex-1 border border-gray-200 text-gray-500 hover:bg-gray-50 text-sm font-medium py-2 rounded-xl transition-all duration-200") Cancelar
                    button(type="submit" class="flex-1 bg-red-500 hover:bg-red-600 text-white text-sm font-medium py-2 rounded-xl transition-all duration-200") Sí, eliminar

block scripts
    script.
        function abrirModalEliminar(id, titulo) {
            document.getElementById('modalTitulo').textContent = titulo;
            document.getElementById('formEliminar').action = `/propiedades/eliminar/${id}`;
            document.getElementById('modalEliminar').classList.remove('hidden');
        }

        function cerrarModalEliminar() {
            document.getElementById('modalEliminar').classList.add('hidden');
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') cerrarModalEliminar();
        });

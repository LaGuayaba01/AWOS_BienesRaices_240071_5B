doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title BienesRaices - #{pagina || 'Inicio'}

        link(rel="stylesheet", href="/css/styles.css")

    body(style="background:#f8fafc; font-family:Arial, sans-serif;")

        // HEADER
        header(style="background:#38bdf8; color:white; padding:10px 0;")
            .container(style="max-width:1100px; margin:auto; display:flex; justify-content:space-between; align-items:center;")

                a(href="/" style="text-decoration:none; font-weight:bold; font-size:18px; color:white;")
                    | Bienes
                    span(style="font-weight:300") Raices

                nav(style="display:flex; gap:15px;")
                    a(href="/" style="color:white; text-decoration:none;") Inicio
                    a(href="/auth/login" style="color:white; text-decoration:none;") Login
                    a(href="/auth/registro" style="background:#22c55e; padding:5px 10px; border-radius:6px; color:white; text-decoration:none;") Registrarse

        // CONTENIDO
        main(style="max-width:1100px; margin:auto; padding:20px;")
            block contenido

        // FOOTER
        footer(style="background:#e2e8f0; text-align:center; padding:10px; color:#475569;")
            | BienesRaices- Y.M.R.G - 240071 © 2025

        block scripts    
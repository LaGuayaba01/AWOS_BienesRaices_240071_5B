extends ../layout/index 

block contenido
    .py-3
        h1.text-3xl.my-3.font-extrabold.text-center.text-purple-600 Bienes
            span.font-normal.text-gray-800 Raíces
        h2.text-center.text-base.font-normal.text-gray-500 Establece tu nueva contraseña

        if errores
            each error in errores
                span(data-alerta-error=error.msg style="display:none")

        .mt-4.mx-auto.max-w-xl
            .bg-white.py-8.px-6.shadow-2xl.rounded-2xl
                form#formReset.space-y-3(method="POST" action=`/auth/actualizarPassword/${token}` noValidate)
                    input(type="hidden" name="_csrf" value=csrfToken)
                  
                    div.px-5
                        label.block.text-xs.uppercase.text-gray-400.mb-1.font-bold(for="passwordUsuario") Nueva contraseña
                        .relative
                            input#passwordUsuario(
                                type="password"
                                placeholder="Por lo menos 8 caracteres"
                                name="passwordUsuario"
                                class="w-full border border-purple-200 px-3 py-1.5 pr-10 rounded-xl text-sm placeholder-gray-400 hover:border-purple-400 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 focus:outline-none transition-all duration-200"
                            )
                            button.absolute.inset-y-0.right-0.flex.items-center.pr-3(
                                type="button"
                                onclick="togglePasswordGroup(this)"
                                tabindex="-1"
                                class="text-purple-300 hover:text-purple-600 transition-colors duration-200"
                                aria-label="Mostrar contraseña"
                            )
                                svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                        p#err-password.hidden.text-red-500.text-xs.mt-1
                        .mt-1.flex.gap-1#barraFuerza
                            span.h-1.flex-1.rounded-full.bg-gray-200#seg1
                            span.h-1.flex-1.rounded-full.bg-gray-200#seg2
                            span.h-1.flex-1.rounded-full.bg-gray-200#seg3
                            span.h-1.flex-1.rounded-full.bg-gray-200#seg4
                        p(class="text-xs text-gray-400 mt-0.5" id="lblFuerza")

                    div.px-5
                        label.block.text-xs.uppercase.text-gray-400.mb-1.font-bold(for="confirmacionUsuario") Confirmación de contraseña
                        .relative
                            input#confirmacionUsuario(
                                type="password"
                                placeholder="Repite la contraseña anterior"
                                name="confirmacionUsuario"
                                class="w-full border border-purple-200 px-3 py-1.5 pr-10 rounded-xl text-sm placeholder-gray-400 hover:border-purple-400 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 focus:outline-none transition-all duration-200"
                            )
                            button.absolute.inset-y-0.right-0.flex.items-center.pr-3(
                                type="button"
                                onclick="togglePasswordGroup(this)"
                                tabindex="-1"
                                class="text-purple-300 hover:text-purple-600 transition-colors duration-200"
                                aria-label="Mostrar confirmación"
                            )
                                svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                        p#err-confirmacion.hidden.text-red-500.text-xs.mt-1
                    
                    div.flex.justify-center.py-3
                        input(
                            type="submit"
                            value="Actualizar Contraseña"
                            class="w-3/4 bg-purple-100 text-purple-700 hover:bg-purple-600 hover:text-white font-bold py-2 cursor-pointer rounded-full shadow-md uppercase text-sm transition-all duration-200"
                        )

block scripts
    script(src="/js/resetearPassword.js")

extends ../layout/index 

block contenido
    .py-4

        h1(style="font-size:26px;font-weight:800;text-align:center;color:#38bdf8")
            | Bienes
            span(style="color:#0f172a;font-weight:400") Raíces

        h2(style="text-align:center;font-size:13px;color:#64748b")
            | Te enviaremos un correo con el enlace de restauración

        if errores
            each error in errores
                span(data-alerta-error=error.msg style="display:none")

        if mensaje
            span(data-alerta-exito=mensaje style="display:none")

        .mt-6.mx-auto(style="max-width:420px;")

            .bg-white(style="padding:20px;border-radius:12px;border:1px solid #e2e8f0;")

                form#formRecuperar(method="POST" action="/auth/recuperarPassword" noValidate)
                    input(type="hidden" name="_csrf" value=csrfToken)

                    // EMAIL
                    div(style="margin-bottom:12px")
                        label(for="emailUsuario" style="font-size:11px;color:#64748b;font-weight:bold")
                            | Correo electrónico

                        input#emailUsuario(
                            type="email"
                            name="emailUsuario"
                            placeholder="correo@dominio.com"
                            autocomplete="email"
                            style="width:100%;border:1px solid #cbd5e1;padding:8px;border-radius:6px;font-size:13px;"
                        )

                        p#err-email.hidden(style="color:red;font-size:11px")

                    // BOTÓN
                    div(style="text-align:center;margin-top:15px")
                        button#btnEnviar(
                            type="submit"
                            style="background:#22c55e;color:white;padding:8px 20px;border:none;border-radius:20px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;justify-content:center;"
                            onmouseover="this.style.background='#16a34a'"
                            onmouseout="this.style.background='#22c55e'"
                        )
                            span#btnTexto Enviar correo
                            span#btnSpinner(style="display:none")
                                | ⏳

                    // LINKS
                    div(style="display:flex;justify-content:space-between;margin-top:12px;font-size:11px")
                        a(href="/auth/login" style="color:#38bdf8;text-decoration:none")
                            | ¿Ya tienes cuenta?

                        a(href="/auth/registro" style="color:#38bdf8;text-decoration:none")
                            | Crear cuenta

    // SCRIPT DIRECTO (SIN BLOCK)
    script(src="/js/recuperarPassword.js")
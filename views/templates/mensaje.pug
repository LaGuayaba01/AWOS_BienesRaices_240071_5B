extends ../layout/index 

block contenido
    .py-6
        h1.text-3xl.my-4.font-extrabold.text-center.text-purple-600 Bienes
            span.font-normal.text-gray-800 Raíces
        h2.text-center.text-base.font-normal.text-gray-500= title
    
    .mt-6.mx-auto.max-w-xl
        .bg-white.py-10.px-8.shadow-2xl.rounded-2xl.text-center
            p.text-base.font-medium.text-gray-600.my-6= msg

            if buttonURL
                .flex.justify-center.mt-8
                    a(href=buttonURL class="inline-flex items-center gap-2 border-2 border-purple-500 text-purple-600 hover:bg-purple-600 hover:text-white font-bold py-2 px-8 rounded-full text-sm uppercase tracking-wide transition-all duration-200 cursor-pointer")
                        svg(xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18")
                        | #{buttonText || 'Regresar'}

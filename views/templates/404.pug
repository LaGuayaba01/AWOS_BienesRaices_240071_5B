extends ../layout/index

block contenido

    .min-h-screen.flex.items-center.justify-center(style="min-height: 60vh;")

        .text-center.px-6.py-12

            //- Número 404 decorativo
            .relative.inline-block.mb-6

                p.font-extrabold.text-transparent.select-none(
                    style="font-size: 8rem; line-height:1; background: linear-gradient(135deg, #7c3aed, #a78bfa, #c4b5fd); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
                ) 404

                //- Casa flotando encima
                .absolute(style="top: 50%; left: 50%; transform: translate(-50%,-50%);")
                    svg(xmlns="http://www.w3.org/2000/svg" style="width:56px; height:56px; color:#7c3aed; filter: drop-shadow(0 4px 12px rgba(124,58,237,0.4));" fill="currentColor" viewBox="0 0 20 20")
                        path(d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z")

            //- Mensaje
            h1.font-bold.text-gray-800.mb-2(style="font-size:1.6rem;") Página no encontrada

            p.text-gray-500.mb-8.mx-auto(style="max-width: 420px; font-size:0.95rem; line-height:1.6;")
                | La propiedad que buscas no existe o fue removida.
                br
                | Pero no te preocupes, tenemos muchas más esperándote.

            //- Botones de acción
            .flex.flex-col.items-center.gap-3(class="sm:flex-row sm:justify-center")

                a(
                    href="/"
                    style="background: linear-gradient(135deg,#7c3aed,#6d28d9); color:white; padding:10px 28px; border-radius:12px; font-size:0.9rem; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:opacity 0.2s;"
                    onmouseover="this.style.opacity='0.88'"
                    onmouseout="this.style.opacity='1'"
                )
                    svg(xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                        path(stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6")
                    | Ver propiedades

                a(
                    href="javascript:history.back()"
                    style="background:white; color:#7c3aed; padding:10px 28px; border-radius:12px; font-size:0.9rem; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:8px; border:2px solid #e9d5ff; transition:border-color 0.2s;"
                    onmouseover="this.style.borderColor='#a78bfa'"
                    onmouseout="this.style.borderColor='#e9d5ff'"
                )
                    svg(xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                        path(stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18")
                    | Regresar

            //- Links de categorías
            .mt-10

                p.text-xs.text-gray-400.uppercase.tracking-widest.mb-4.font-semibold ¿Qué tipo de propiedad buscas?

                .flex.flex-wrap.justify-center.gap-2

                    a(href="/categorias/casa" style="display:inline-flex; align-items:center; gap:6px; background:#f5f3ff; color:#6d28d9; padding:7px 16px; border-radius:999px; font-size:0.82rem; font-weight:600; text-decoration:none; border:1px solid #ede9fe; transition:background 0.2s;" onmouseover="this.style.background='#ede9fe'" onmouseout="this.style.background='#f5f3ff'")
                        svg(xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" fill="currentColor" viewBox="0 0 20 20")
                            path(d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z")
                        | Casas

                    a(href="/categorias/departamento" style="display:inline-flex; align-items:center; gap:6px; background:#f5f3ff; color:#6d28d9; padding:7px 16px; border-radius:999px; font-size:0.82rem; font-weight:600; text-decoration:none; border:1px solid #ede9fe; transition:background 0.2s;" onmouseover="this.style.background='#ede9fe'" onmouseout="this.style.background='#f5f3ff'")
                        svg(xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" fill="currentColor" viewBox="0 0 20 20")
                            path(fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd")
                        | Departamentos

                    a(href="/categorias/terreno" style="display:inline-flex; align-items:center; gap:6px; background:#f5f3ff; color:#6d28d9; padding:7px 16px; border-radius:999px; font-size:0.82rem; font-weight:600; text-decoration:none; border:1px solid #ede9fe; transition:background 0.2s;" onmouseover="this.style.background='#ede9fe'" onmouseout="this.style.background='#f5f3ff'")
                        svg(xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z")
                        | Terrenos
